# App settings
APP_NAME="BridgeMart API"       # Application name
APP_VERSION="0.1.0"             # Application version
ENVIRONMENT="development"       # Environment: development, staging, production

# Server settings
HOST="localhost"    # Server host
PORT="8080"         # Server port

# CORS settings
CORS_ORIGINS=["http://localhost:5173"]      # Allowed origins for CORS

# Ollama settings
EMBEDDING_MODEL="nomic-embed-text"          # Ollama embedding model name

# Embedding job settings
MAX_FILE_SIZE_MB=50                 # Maximum file size in megabytes
MAX_DATASET_ROWS=50000              # Maximum number of rows per dataset
EMBEDDING_CHUNK_SIZE=256            # Number of rows per embedding chunk

# Similarity search settings
TOP_K=10                            # Number of top similar datasets to return
K_ROWS=100                          # Number of rows to consider for similarity search
SIMILARITY_THRESHOLD=0.75           # Similarity score threshold

# Pinata IPFS settings
PINATA_API_KEY=""                                        # Your Pinata API Key
PINATA_SECRET_KEY=""                                     # Your Pinata Secret Key
PINATA_GATEWAY_URL="https://gateway.pinata.cloud"        # Pinata Gateway URL

# Smart contract settings
CONTRACT_ADDRESS="0xYourContractAddressHere"                            # Your smart contract address
CONTRACT_ABI_PATH="./path/to/your/contract_abi.json"                    # Path to your contract ABI JSON file
CHAIN_ID=11155111                                                       # Sepolia testnet chain ID
RPC_URL="https://sepolia.infura.io/v3/your-infura-project-id"           # Your Ethereum RPC URL
