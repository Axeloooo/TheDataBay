# =============================================================================
# TheDataBay monorepo — single env file for all tools
# Copy to .env and fill in values. Never commit .env.
# =============================================================================

# ── Shared (API + client + mobile + EVM) ─────────────────────────────────────
CONTRACT_ADDRESS=""
PAYMENT_TOKEN_ADDRESS=""
CADC_TOKEN_ADDRESS=""
CHAIN_ID="31337"
RPC_URL="http://127.0.0.1:8545"
EXPLORER_URL=""
PINATA_GATEWAY_URL="https://gateway.pinata.cloud"
WALLETCONNECT_PROJECT_ID=""

# ── Client (consumed by Vite via vite.config.ts remapping) ───────────────────
API_URL="http://localhost:8080"

# ── API (FastAPI backend) ─────────────────────────────────────────────────────
APP_NAME="TheDataBay API"
APP_VERSION="0.1.0"
ENVIRONMENT="development"
HOST="0.0.0.0"
PORT="8080"
CORS_ORIGINS='["http://localhost:5173"]'

LLM_PROVIDER="openai"
LLM_CHAT_MODEL="gpt-4o-mini"
LLM_EMBEDDING_MODEL="text-embedding-3-small"
LLM_EMBEDDING_DIMENSION="1536"
LLM_THINK="false"
OPENAI_API_KEY=""
# Ollama fallback (only when LLM_PROVIDER=ollama)
OLLAMA_API_KEY=""
LLM_BASE_URL="http://localhost:11434"
LLM_EMBEDDING_BASE_URL="http://localhost:11434"

DATASET_SUMMARY_COUNT="5"
DATASET_SUMMARY_SAMPLE_ROWS="20"
MAX_FILE_SIZE_MB="50"
MAX_DATASET_ROWS="50000"

TOP_K="10"
SIMILARITY_THRESHOLD="0.50"
CACHE_MAXSIZE="100"

PINATA_API_KEY=""
PINATA_SECRET_KEY=""

POSTGRES_URL="postgresql+psycopg://thedatabay:thedatabay@localhost:5432/thedatabay_db"
POSTGRES_DB="thedatabay_db"
POSTGRES_USER="thedatabay"
POSTGRES_PASSWORD="thedatabay"

CONTRACT_ABI_PATH="api/app/contracts/Marketplace.json"
SERVER_PRIVATE_KEY=""
SEED_AGENTS="true"

# ── EVM / Anvil ───────────────────────────────────────────────────────────────
ANVIL_RPC_URL="http://127.0.0.1:8545"
ANVIL_PRIVATE_KEY="0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80"
ANVIL_FEE_RECIPIENT=""
ANVIL_FEE_BPS="0"
# Optional: leave unset to mint to the deployer address
ANVIL_USDC_RECIPIENT=""
ANVIL_CADC_RECIPIENT=""

# ── EVM / Base Sepolia (chain 84532) ──────────────────────────────────────────
BASE_SEPOLIA_RPC_URL=""
BASE_SEPOLIA_PRIVATE_KEY=""
BASE_SEPOLIA_USDC_ADDRESS="0x0000000000000000000000000000000000000000"
BASE_SEPOLIA_USDC_DECIMALS="6"
BASE_SEPOLIA_USDC_MAX_PRICE="1000000000000"
BASE_SEPOLIA_CADC_ADDRESS="0x0000000000000000000000000000000000000000"
BASE_SEPOLIA_CADC_DECIMALS="18"
BASE_SEPOLIA_CADC_MAX_PRICE="1000000000000000000000000"
BASE_SEPOLIA_FEE_RECIPIENT=""
BASE_SEPOLIA_FEE_BPS="250"
ETHERSCAN_API_KEY=""

# ── Mint (MintMockTokens script) ──────────────────────────────────────────────
# Recipient for make mint-tokens-anvil / mint-tokens-base-sepolia
# Leave blank to default to the deployer address.
MINT_RECIPIENT=""
MINT_USDC_AMOUNT="10000000000"
MINT_CADC_AMOUNT="10000000000000000000000"
