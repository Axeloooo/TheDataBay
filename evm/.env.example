# Anvil RPC URL
ANVIL_RPC_URL="http://127.0.0.1:8545"

# Anvil private key
ANVIL_PRIVATE_KEY="0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80"

# Anvil fee config
ANVIL_FEE_RECIPIENT="0xYourFeeRecipientAddress"
ANVIL_FEE_BPS=0

# Optional Anvil mock token mint recipients. Leave unset to mint to the deployer.
# ANVIL_USDC_RECIPIENT="0x0000000000000000000000000000000000000000"
# ANVIL_CADC_RECIPIENT="0x0000000000000000000000000000000000000000"

# Sepolia RPC URL (Alchemy)
SEPOLIA_RPC_URL="https://eth-sepolia.g.alchemy.com/v2/your-api-key"

# Sepolia private key 
SEPOLIA_PRIVATE_KEY=""

# Sepolia USDC token address. Zero address intentionally deploys a public-mint MockUSDC on Ethereum Sepolia.
SEPOLIA_USDC_ADDRESS="0x0000000000000000000000000000000000000000"
SEPOLIA_USDC_DECIMALS=6
SEPOLIA_USDC_MAX_PRICE=1000000000000

# Sepolia CADC token address. Zero address intentionally deploys a public-mint MockCADC on Ethereum Sepolia.
# Production-target/reference CADC address 0x043eb4b75d0805c43d7c834902e335621983cf03 is not used on Ethereum Sepolia.
SEPOLIA_CADC_ADDRESS="0x0000000000000000000000000000000000000000"
SEPOLIA_CADC_DECIMALS=18
SEPOLIA_CADC_MAX_PRICE=1000000000000000000000000

# Optional seed payment token override
# SEED_PAYMENT_TOKEN="0xYourUsdcTokenAddress"

# Sepolia fee config
SEPOLIA_FEE_RECIPIENT="0xYourFeeRecipientAddress"
SEPOLIA_FEE_BPS=0

# Etherscan API Key
ETHERSCAN_API_KEY="your-etherscan-api-key"
