# See secrets.example.yaml for documentation on all available secret values
apiVersion: v1
kind: Secret
metadata:
  name: bridgemart-secrets
type: Opaque
stringData:
  # PostgreSQL settings (shared by app + SonarQube in local dev)
  POSTGRES_URL: "postgresql://bridgemart:bridgemart@postgres-svc:5432/bridgemart_db"
  POSTGRES_DB: "bridgemart_db"
  POSTGRES_USER: "bridgemart"
  POSTGRES_PASSWORD: "bridgemart"

  # App settings
  APP_NAME: "BridgeMart API"
  APP_VERSION: "0.1.0"
  ENVIRONMENT: "development"

  # Server settings
  HOST: "0.0.0.0"
  PORT: "8080"

  API_URL: "http://localhost:8080"

  # CORS settings
  CORS_ORIGINS: '["http://localhost:5173"]'

  # Ollama settings
  EMBEDDING_MODEL: "nomic-embed-text"

  # Embedding job settings
  MAX_FILE_SIZE_MB: "50"
  MAX_DATASET_ROWS: "50000"
  EMBEDDING_CHUNK_SIZE: "256"

  # Similarity search settings
  TOP_K: "10"
  K_ROWS: "100"
  SIMILARITY_THRESHOLD: "0.75"
  CACHE_MAXSIZE: "100"

  # Pinata IPFS settings
  PINATA_API_KEY: "da12b153ef83ddd9116d"
  PINATA_SECRET_KEY: "f4bcb2ca691ff6fb6a1f9c7443da815a8b6b7e6e64456637479cbd5e644eacd7"
  PINATA_GATEWAY_URL: "https://gateway.pinata.cloud"

  # Smart contract settings
  CONTRACT_ADDRESS: "0xdc64a140aa3e981100a9beca4e685f962f0cf6c9"
  CONTRACT_ABI_PATH: "/code/app/contracts/Marketplace.json"
  CHAIN_ID: "31337"
  RPC_URL: "http://host.docker.internal:8545"
  SERVER_PRIVATE_KEY: "0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80"

  # Agent settings
  SEED_AGENTS: "true"

  # WalletConnect settings
  WALLETCONNECT_PROJECT_ID: "aef9c3ff64c92328659b3d5b73adb8d9"
  PAYMENT_TOKEN_ADDRESS: "0x5FbDB2315678afecb367f032d93F642f64180aa3"\n  CADC_TOKEN_ADDRESS: "0x9fE46736679d2D9a65F0992F2272dE9f3c7fa6e0"\n